{
  "expo": {
    "name": "Product +ive",
    "slug": "product-ive",
    "version": "1.3.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "productive",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nxadx.productive",
      "icon": {
        "light": "./assets/images/icon.png",
        "dark": "./assets/images/icon-dark.png",
        "tinted": "./assets/images/icon-tinted.png"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.aadarshlokhande.productive",
      "versionCode": 12
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000",
            "image": "./assets/images/splash-icon-dark.png"
          }
        }
      ],
      "expo-font",
      "expo-image",
      "expo-sqlite",
      "expo-web-browser",
      "expo-sharing",
      "expo-notifications",
      [
        "expo-widgets",
        {
          "widgets": [
            {
              "name": "ProductiveGlance",
              "entry": "./src/widgets/ProductiveGlance.tsx",
              "displayName": "Productive+ Glance",
              "description": "Weekly XP and Streak status.",
              "supportedFamilies": [
                "systemSmall",
                "systemMedium"
              ]
            }
          ]
        }
      ],
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "ProductivePlusWidget",
              "label": "Productive+ Glance",
              "minWidth": "200dp",
              "minHeight": "100dp",
              "description": "Weekly XP and Streak status.",
              "previewImage": "./assets/images/widget-preview.png"
            }
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "78edffbe-90a1-48db-bff4-dfd1cde61af7"
      }
    }
  }
}
